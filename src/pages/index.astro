---
import Layout from '@/layouts/Layout.astro';

type LobbyTileBg =
  | { type: 'image'; src: string }
  | { type: 'blackjack' }
  | { type: 'frootjarz' };

interface GameTile {
  title: string;
  subtitle: string;
  href: string;
  accent: string;
  /** Game logo under `public/`; emoji fallback when omitted */
  logoSrc?: string;
  /** Taller logo area + wider cap (e.g. portrait / padded PNG art) */
  logoSlot?: 'default' | 'tall';
  /** Full-bleed background (in-game art or felt-style CSS) */
  tileBg?: LobbyTileBg;
  icon: string;
  available: boolean;
}

const games: GameTile[] = [
  {
    title: 'Blackjack',
    subtitle: 'Multi-Hand with 21+3 & Perfect Pairs',
    href: '/blackjack',
    accent: 'from-purple-500 to-fuchsia-500',
    logoSrc: '/cards/multihand%20logo.png',
    tileBg: { type: 'blackjack' },
    icon: '🃏',
    available: true,
  },
  {
    title: 'Bamboo Fortunes',
    subtitle: '7x7 Cluster Pays with Symbol Multipliers',
    href: '/bamboofortunes',
    accent: 'from-emerald-500 to-green-600',
    logoSrc: '/bamboofortunes/logo.png',
    tileBg: { type: 'image', src: '/bamboofortunes/bg.png' },
    icon: '🐼',
    available: true,
  },
  {
    title: 'Froot Jarz',
    subtitle: 'Cluster Pays Cascading Slot',
    href: '/frootjarz',
    accent: 'from-amber-400 to-orange-500',
    logoSrc: '/frootshoot/LOGO.png',
    logoSlot: 'tall',
    tileBg: { type: 'frootjarz' },
    icon: '🍓',
    available: true,
  },
  {
    title: 'Hot Fiesta',
    subtitle: '7x7 Cluster Pays with Multipliers & Free Spins',
    href: '/hotfiesta',
    accent: 'from-red-500 to-orange-500',
    logoSrc: '/hotfiesta/logo.png',
    tileBg: { type: 'image', src: '/hotfiesta/bg.png' },
    icon: '🌮',
    available: true,
  },
  {
    title: 'Breaking Bandits',
    subtitle: '5x3 Western Slot with Wild Features & Gamble',
    href: '/bandits',
    accent: 'from-amber-600 to-orange-700',
    logoSrc: '/bandits/logo.png',
    tileBg: { type: 'image', src: '/bandits/bg2.png' },
    icon: '🤠',
    available: true,
  },
  {
    title: 'Baccarat',
    subtitle: 'Punto Banco',
    href: '/baccarat',
    accent: 'from-amber-500 to-orange-500',
    icon: '🎴',
    available: false,
  },
  {
    title: 'Hi-Lo',
    subtitle: 'Higher or Lower Card Game',
    href: '/hilo',
    accent: 'from-rose-500 to-pink-500',
    icon: '🔮',
    available: false,
  },
];
---

<Layout title="Spiffing Casino">
  <div class="relative flex h-dvh flex-col overflow-y-auto bg-[#0e0620]">
    {/*
      CSS-only backdrop (matches preloader base: #0e0620 + purple/pink glows).
      No React island — keeps the lobby resilient in dev/build.
    */}
    <div class="pointer-events-none fixed inset-0 z-0" aria-hidden="true">
      <div class="absolute inset-0 bg-[#0e0620]" />
      <div
        class="absolute inset-0 opacity-100 bg-[radial-gradient(ellipse_75%_55%_at_30%_78%,rgba(168,85,247,0.14),transparent_58%)]"
      />
      <div
        class="absolute inset-0 opacity-100 bg-[radial-gradient(ellipse_60%_48%_at_72%_22%,rgba(236,72,153,0.1),transparent_52%)]"
      />
    </div>

    <div class="relative z-10 flex min-h-0 flex-1 flex-col">
    <header class="shrink-0 px-6 pb-2 pt-[max(2.5rem,calc(env(safe-area-inset-top)+1.5rem))] text-center sm:pt-14">
      <img
        src="/logo-spiffing.svg"
        alt="Spiffing Studios"
        class="mx-auto mb-5 h-[min(42vw,10.5rem)] w-auto sm:mb-6 sm:h-[11.5rem] lg:h-[12.5rem]"
        onerror="this.style.display='none'"
      />
      <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl lg:text-5xl">
        Choose Your Game
      </h1>
      <p class="mt-2 text-sm font-medium tracking-wide text-white/40 sm:text-base">
        Select a table to start playing
      </p>
    </header>

    <main class="mx-auto w-full max-w-3xl flex-1 px-5 py-8 sm:px-8 sm:py-12">
      <div class="grid grid-cols-2 gap-4 sm:gap-5 lg:gap-6">
        {games.map((game) => (
          <a
            href={game.available ? game.href : undefined}
            class:list={[
              'group relative flex h-full min-h-[260px] flex-col overflow-hidden rounded-2xl border transition-all duration-300 sm:min-h-[280px]',
              game.available
                ? game.tileBg
                  ? 'cursor-pointer border-white/10 bg-transparent hover:border-white/25 hover:shadow-lg hover:shadow-purple-500/15 active:scale-[0.98]'
                  : 'cursor-pointer border-white/10 bg-white/[0.04] hover:border-white/20 hover:bg-white/[0.07] hover:shadow-lg hover:shadow-purple-500/10 active:scale-[0.98]'
                : 'cursor-default border-white/[0.05] bg-white/[0.02] opacity-50',
            ]}
          >
            {game.tileBg && (
              <div
                class="pointer-events-none absolute inset-0 z-0 overflow-hidden rounded-2xl"
                aria-hidden="true"
              >
                {game.tileBg.type === 'image' && (
                  <div class="relative h-full w-full">
                    <img
                      src={game.tileBg.src}
                      alt=""
                      class="absolute inset-0 h-full w-full object-cover object-center"
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="absolute inset-0 bg-gradient-to-b from-black/15 via-black/48 to-black/90" />
                  </div>
                )}
                {game.tileBg.type === 'blackjack' && (
                  <div class="relative h-full min-h-0 w-full">
                    <div class="lobby-tile-bg-blackjack" />
                    <div class="lobby-tile-bg-blackjack-tint" />
                  </div>
                )}
                {game.tileBg.type === 'frootjarz' && (
                  <div class="relative h-full min-h-0 w-full">
                    <div class="lobby-tile-bg-frootjarz" />
                    <div class="fj-bg-pattern absolute inset-0 opacity-[0.11]" />
                    <div class="lobby-tile-bg-frootjarz-tint" />
                  </div>
                )}
              </div>
            )}

            <div
              class:list={[
                'relative z-[1] flex min-h-0 flex-1 flex-col',
                game.tileBg && game.available && 'transition-colors group-hover:bg-white/[0.05]',
              ]}
            >
              <div class={`relative h-1.5 w-full shrink-0 bg-gradient-to-r ${game.accent}`} />

              <div class="flex flex-1 flex-col items-center justify-center px-4 py-8 text-center sm:px-6 sm:py-10 lg:py-14">
                <div
                  class:list={[
                    'mb-4 flex w-full items-center justify-center',
                    game.logoSlot === 'tall'
                      ? 'h-[9rem] sm:h-[11.5rem] lg:h-[14rem]'
                      : 'h-[6.5rem] sm:h-[8rem] lg:h-40',
                  ]}
                >
                  {game.logoSrc ? (
                    <img
                      src={game.logoSrc}
                      alt={`${game.title} logo`}
                      class:list={[
                        'max-h-full w-auto object-contain object-center drop-shadow-[0_6px_24px_rgba(0,0,0,0.55)]',
                        game.logoSlot === 'tall'
                          ? 'max-w-[min(100%,26rem)]'
                          : 'max-w-[min(100%,20rem)]',
                      ]}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <span class="text-4xl sm:text-5xl lg:text-6xl" aria-hidden="true">
                      {game.icon}
                    </span>
                  )}
                </div>
                <h2 class="text-base font-bold tracking-tight text-white drop-shadow-[0_2px_14px_rgba(0,0,0,0.85)] sm:text-lg lg:text-xl">
                  {game.title}
                </h2>
                <p class="mt-1 text-[11px] font-medium leading-snug text-white/55 drop-shadow-[0_1px_10px_rgba(0,0,0,0.75)] sm:text-xs">
                  {game.subtitle}
                </p>
              </div>

              {game.available && (
                <div
                  class:list={[
                    'shrink-0 border-t px-4 py-3 text-center backdrop-blur-sm',
                    game.tileBg
                      ? 'border-white/10 bg-black/40'
                      : 'border-white/[0.06]',
                  ]}
                >
                  <span class="text-[11px] font-bold uppercase tracking-[0.14em] text-white/55 transition-colors group-hover:text-white/85">
                    Play Now
                  </span>
                </div>
              )}
            </div>

            {!game.available && (
              <div class="absolute inset-0 z-[5] flex items-center justify-center rounded-2xl bg-black/35">
                <span class="rounded-full bg-white/10 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-white/50">
                  Coming Soon
                </span>
              </div>
            )}
          </a>
        ))}
      </div>
    </main>

    <footer class="shrink-0 pb-[max(1rem,env(safe-area-inset-bottom))] pt-4 text-center text-[10px] font-medium tracking-wide text-white/25 sm:text-[11px]">
      Spiffing Studios &mdash; Play Responsibly
    </footer>
    </div>
  </div>
</Layout>
